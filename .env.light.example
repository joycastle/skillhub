# Copy this file to .env.light and edit the values.
#
# cp .env.light.example .env.light

# Java installed by Homebrew on Apple Silicon.
export JAVA_HOME="/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home"
export PATH="/opt/homebrew/opt/openjdk@21/bin:$PATH"

# Local service URLs.
export SKILLHUB_PUBLIC_BASE_URL="http://localhost:8080"
export SKILLHUB_WEB_BASE_URL="http://localhost:3000"

# API tokens and CLI device auth (disabled for internal light deployment).
export SKILLHUB_API_TOKENS_ENABLED=false
export VITE_SKILLHUB_API_TOKENS_ENABLED=false

# Publish without review; hide governance/report/review UI.
export SKILLHUB_PUBLISH_AUTO_PUBLISH=true
export SKILLHUB_GOVERNANCE_ENABLED=false
export VITE_SKILLHUB_GOVERNANCE_ENABLED=false

# Feishu Web login.
# In Feishu developer console for THIS app id:
#   开发配置 -> 安全设置 -> 重定向 URL
# Local dev should use the frontend origin so the browser session cookie works:
#   http://localhost:3000/login/oauth2/code/feishu
# Also enable permission in 权限管理:
#   contact:user.base:readonly
export OAUTH2_FEISHU_CLIENT_ID="replace-with-feishu-client-id"
export OAUTH2_FEISHU_CLIENT_SECRET="replace-with-feishu-client-secret"
export OAUTH2_FEISHU_SCOPE="contact:user.base:readonly"

# Hermes Agent -> SkillHub short-lived JWT.
# Use the same value in Hermes Agent when it signs SkillHub JWTs.
export HERMES_SKILLHUB_JWT_SECRET="dev-replace-with-a-long-random-secret"
export HERMES_SKILLHUB_JWT_ISSUER="hermes-agent"

# Local development scanner.
export SKILLHUB_SECURITY_SCANNER_ENABLED=true
export SKILLHUB_SECURITY_SCANNER_URL="http://localhost:8000"
export SKILLHUB_SECURITY_SCANNER_MODE=upload
